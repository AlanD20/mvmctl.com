---
import { ClientRouter } from "astro:transitions";
import { navLinks } from "../content/site/landing";
import Icon from "../components/ui/Icon.astro";
import { getIcon } from "../lib/icons";

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image = "/favicon.svg" } = Astro.props;
const isExternalLink = (href: string) => href.startsWith("http");
const normalizePath = (path: string) => {
  const trimmed = path.replace(/\/+$/, "");
  return trimmed === "" ? "/" : trimmed;
};
const currentPath = normalizePath(Astro.url.pathname);
const siteUrl = Astro.site?.toString() ?? "https://mvmctl.aland20.com";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
const isDocsPage = currentPath.startsWith("/docs");
const primaryNavLinks = navLinks.filter((item) => normalizePath(item.href) !== "/docs");
const isActiveLink = (href: string) => {
  if (href.startsWith("/#")) {
    const section = href.slice(2);

    if (section === "features") {
      return currentPath === "/feature" || currentPath === "/features";
    }

    if (section === "install") {
      return currentPath === "/install";
    }

    return currentPath === "/";
  }

  const target = normalizePath(href);

  if (target === "/features") {
    return currentPath === "/feature" || currentPath === "/features";
  }

  return currentPath === target;
};
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <link rel='canonical' href={canonicalUrl} />
    <ClientRouter />
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      href='https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap'
      rel='stylesheet'
    />
    <meta name='generator' content='Astro' />
    <meta name='description' content={description} />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:type' content='website' />
    <meta property='og:url' content={canonicalUrl} />
    <meta property='og:image' content={imageUrl} />
    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    <meta name='twitter:image' content={imageUrl} />
    <meta name='theme-color' content='#09090b' />
    <title>{title}</title>
  </head>
  <body>
    <div class='bg-orb orb-a' aria-hidden='true'></div>
    <div class='bg-orb orb-b' aria-hidden='true'></div>
    <div class='scroll-progress' aria-hidden='true'>
      <span data-anim='scroll-progress-bar'></span>
    </div>
    <header class='nav-wrap' data-anim='site-header'>
      <div class='site-header'>
        <a href='/' class='brand'>
          <span class='brand-glyph' data-anim='brand-dot'>
            <img
              src='/favicon.svg'
              alt='mvmctl'
              class='brand-favicon'
              width='16'
              height='16'
            />
          </span>
          <span class='brand-text'>
            <strong>mvmctl</strong>
          </span>
        </a>

        <nav>
          <ul>
            {
              primaryNavLinks.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class={isActiveLink(item.href) ? "active" : undefined}
                    aria-current={isActiveLink(item.href) ? "page" : undefined}
                    target={isExternalLink(item.href) ? "_blank" : undefined}
                    rel={isExternalLink(item.href) ? "noopener noreferrer" : undefined}
                    data-anim='nav-link'>
                    <Icon
                      icon={getIcon(item.icon)}
                      size='0.75rem'
                      class='nav-icon'
                    />
                    <span class='nav-label'>{item.label}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <div class='nav-actions'>
          {
            isDocsPage ? (
              <button class='docs-left-toggle' type='button' aria-label='Toggle docs sections'>
                <Icon
                  icon={getIcon("bars")}
                  size='0.75rem'
                  class='docs-left-toggle-icon'
                />
              </button>
            ) : null
          }
          <a class='header-link' href='/docs/'>
            <Icon
              icon={getIcon("book")}
              size='0.75rem'
              class='header-link-icon'
            />
            <span>Docs</span>
          </a>
        </div>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class='site-footer'>
      <p>mvmctl · MIT Licensed</p>
    </footer>

    <script>
      import "../scripts/animations/router";

      const bindDocsMenuToggle = () => {
        const toggle = document.querySelector(".docs-left-toggle");
        const leftNav = document.querySelector(".left-nav");

        if (!(toggle instanceof HTMLButtonElement) || !(leftNav instanceof HTMLElement)) {
          return;
        }

        const closeMenu = () => {
          leftNav.classList.remove("mobile-open");
          toggle.classList.remove("active");
          toggle.setAttribute("aria-expanded", "false");
        };

        const syncToggleVisibility = () => {
          const shouldShowToggle = window.innerWidth <= 980;
          toggle.hidden = !shouldShowToggle;

          if (!shouldShowToggle) {
            closeMenu();
          }
        };

        if (toggle.dataset.bound === "true") {
          syncToggleVisibility();
          return;
        }

        toggle.dataset.bound = "true";

        toggle.setAttribute("aria-expanded", "false");
        toggle.addEventListener("click", () => {
          if (toggle.hidden) {
            return;
          }

          const open = !leftNav.classList.contains("mobile-open");
          leftNav.classList.toggle("mobile-open", open);
          toggle.classList.toggle("active", open);
          toggle.setAttribute("aria-expanded", open ? "true" : "false");
        });

        document.querySelectorAll("[data-docs-left-link]").forEach((link) => {
          if (!(link instanceof HTMLAnchorElement)) {
            return;
          }

          if (link.dataset.mobileCloseBound === "true") {
            return;
          }

          link.dataset.mobileCloseBound = "true";
          link.addEventListener("click", closeMenu);
        });

        document.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Node)) {
            return;
          }

          if (toggle.contains(target) || leftNav.contains(target)) {
            return;
          }

          closeMenu();
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            closeMenu();
          }
        });

        window.addEventListener("resize", syncToggleVisibility);
        syncToggleVisibility();
      };

      const checkFavicons = () => {
        document.querySelectorAll(".brand-favicon").forEach((img) => {
          if (img instanceof HTMLImageElement && img.complete) {
            img.classList.add("is-loaded");
            const glyph = img.closest(".brand-glyph");
            if (glyph) glyph.classList.add("is-loaded");
          }
        });
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", () => {
          bindDocsMenuToggle();
          checkFavicons();
        }, { once: true });
      } else {
        bindDocsMenuToggle();
        checkFavicons();
      }

      document.addEventListener("astro:page-load", () => {
        bindDocsMenuToggle();
        checkFavicons();
      });
    </script>
  </body>
</html>

