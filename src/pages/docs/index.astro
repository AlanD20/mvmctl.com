---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DocsNavLeft from "../../components/docs/DocsNavLeft.astro";
import DocsQuickstartArticle from "../../components/docs/DocsQuickstartArticle.astro";
import DocsOnThisPage from "../../components/docs/DocsOnThisPage.astro";
---

<BaseLayout
  title="mvmctl docs · Installation, quick start, and command reference"
  description="Documentation for mvmctl — the microVM manager for Linux. Installation, prerequisites, host initialization, quick start guide, VM lifecycle, resource management, networking, cloud-init, configuration, and troubleshooting."
>
  <div class="docs-shell">
    <DocsNavLeft />
    <DocsQuickstartArticle />
    <DocsOnThisPage />
  </div>
</BaseLayout>

<style>
  .docs-shell {
    width: calc(100vw - 2rem);
    max-width: 1320px;
    margin: 0 auto 5rem;
    padding: 0;
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr) 220px;
    gap: 2rem;
  }

  .docs-shell :global(.left-nav) {
    grid-column: 1;
  }

  .docs-shell :global(.article) {
    grid-column: 2;
    min-width: 0;
  }

  @media (max-width: 1200px) {
    .docs-shell {
      grid-template-columns: 240px minmax(0, 1fr);
    }
  }

  @media (max-width: 1060px) {
    .docs-shell {
      grid-template-columns: 220px minmax(0, 1fr);
      gap: 1.25rem;
    }

    .docs-shell :global(.article) {
      justify-self: center;
      width: min(100%, 72ch);
    }
  }

  @media (max-width: 980px) {
    .docs-shell {
      grid-template-columns: minmax(0, 1fr);
      gap: 1rem;
    }

    .docs-shell :global(.left-nav),
    .docs-shell :global(.article) {
      grid-column: 1;
    }

    .docs-shell :global(.article) {
      justify-self: center;
      width: min(100%, 72ch);
    }
  }

  @media (max-width: 760px) {
    .docs-shell {
      width: calc(100vw - 2rem);
      margin: 0 auto 3rem;
      gap: 1rem;
      grid-template-columns: minmax(0, 1fr);
    }

    .docs-shell :global(.left-nav),
    .docs-shell :global(.article) {
      grid-column: 1;
    }
  }
</style>
