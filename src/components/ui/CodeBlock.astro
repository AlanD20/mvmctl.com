---
import Icon from "./Icon.astro";
import { getIcon } from "../../lib/icons";

interface Props {
  lines: readonly string[];
  caption?: string;
  compact?: boolean;
}

const { lines, caption, compact = false } = Astro.props;
---

<div class={`code-wrap ${compact ? "compact" : ""}`}>
  <div class="code-top">
    <div class="code-top-label">
      <Icon icon={getIcon("terminal")} size="0.75rem" class="code-terminal-icon" />
      <p class="code-caption">{caption ?? "Terminal"}</p>
    </div>
    <div class="code-top-actions"></div>
  </div>
  <pre data-anim="code-block"><code>{lines.join("\n")}</code></pre>
</div>

<style>
  .code-wrap {
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: var(--color-surface-5);
    overflow: hidden;
    transition: border-color 180ms ease;
  }

  .code-wrap:hover {
    border-color: var(--color-accent-primary-74);
  }

  :global(.hero-panel) .code-wrap {
    background: transparent;
  }

  .code-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .code-top-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-code-muted);
  }

  .code-terminal-icon {
    color: currentColor;
  }

  .code-top-actions {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.5rem;
    margin-left: auto;
    min-height: 1.5rem;
  }

  .code-wrap.compact.with-copy .code-top {
    flex-wrap: nowrap;
    align-items: center;
    row-gap: 0;
  }

  .code-wrap.compact.with-copy .code-top-label {
    min-width: 0;
    flex: 1 1 auto;
    overflow: hidden;
  }

  .code-wrap.compact.with-copy .code-top-actions {
    flex: 0 0 auto;
    margin-left: auto;
    min-width: fit-content;
  }

  @media (max-width: 560px) {
    .code-wrap.compact.with-copy .code-top {
      padding: 0.5rem 0.75rem;
      gap: 0.5rem;
    }

    .code-wrap.compact.with-copy .code-top-label {
      width: auto;
    }

    .code-wrap.compact.with-copy .code-top-actions {
      width: auto;
      justify-content: flex-end;
    }

    .code-wrap.compact.with-copy .code-caption {
      line-height: 1.25;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      display: block;
    }
  }

  @media (max-width: 220px) {
    .code-wrap.compact.with-copy .code-top {
      padding: 0.25rem 0.5rem;
      gap: 0.25rem;
    }

    .code-wrap.compact.with-copy .code-top-label {
      gap: 0.25rem;
    }

    .code-wrap.compact.with-copy .code-caption {
      font-size: 0.75rem;
      line-height: 1.1;
    }
  }

  .code-caption {
    margin: 0;
    color: var(--color-text-code-muted);
    font-size: 0.75rem;
    letter-spacing: 0;
    line-height: 1;
  }

  pre[data-anim="code-block"] {
    color: var(--color-text-code);
    transition: color 180ms ease;
  }

  pre {
    margin: 0;
    padding: 1rem;
    overflow-x: auto;
    opacity: 1;
  }

  .code-wrap.compact pre {
    padding: 0.75rem 1rem;
  }

  code {
    font-family: "Geist Mono", "JetBrains Mono", "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 0.75rem;
    line-height: 1.55;
    color: currentColor;
    white-space: pre;
    opacity: 1;
  }

  .code-wrap:hover .code-top-label,
  .code-wrap:hover .code-caption,
  .code-wrap:hover .code-terminal-icon {
    color: var(--color-text-code-hover);
  }

  .code-wrap:hover pre[data-anim="code-block"] {
    color: var(--color-text-code-bright);
  }
</style>
