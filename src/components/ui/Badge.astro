---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<span class='badge' data-anim='badge'>{text}</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--color-accent-primary-border-32);
    border-radius: 999px;
    padding: 0.5rem 1rem;
    color: var(--color-text-badge);
    background: linear-gradient(
      135deg,
      var(--color-accent-primary-surface-60),
      var(--color-accent-primary-surface-68)
    );
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    box-shadow:
      inset 0 0 0px 0px var(--color-accent-primary-border-32),
      0px 0px 20px 0px var(--color-accent-primary-shadow-18);
    transition: border-color 180ms ease, color 180ms ease;
  }

  .badge:hover {
    border-color: var(--color-accent-primary-68);
    color: var(--color-text-primary-soft-2);
  }
</style>
