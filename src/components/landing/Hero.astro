---
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";
import CodeBlock from "../ui/CodeBlock.astro";
import Icon from "../ui/Icon.astro";
import { hero } from "../../content/site/landing";
import { getIcon } from "../../lib/icons";
---

<section class='hero' data-anim='hero-root'>
  <div class='hero-grid' data-anim='hero-grid'></div>
  <div class='hero-copy'>
    <Badge text={hero.badge} />
    <h1 data-anim='hero-title'>{hero.title}</h1>
    <p data-anim='hero-desc'>{hero.description}</p>
    <div class='hero-actions' data-anim='hero-actions'>
      <Button
        href={hero.primaryCta.href}
        label={hero.primaryCta.label}
        iconLeft='download'
        iconRight={true}
      />
      <Button
        href={hero.secondaryCta.href}
        label={hero.secondaryCta.label}
        variant='ghost'
        iconLeft='book'
        iconRight={true}
      />
      <Button
        href={hero.tertiaryCta.href}
        label={hero.tertiaryCta.label}
        variant='ghost'
        external={true}
        iconLeft='github'
      />
    </div>

    <div class='hero-metrics' data-anim='hero-metrics'>
      {
        hero.metrics.map((metric) => (
          <article>
            <div class="metric-head">
              <Icon icon={getIcon(metric.icon)} size="0.75rem" class="metric-icon" />
              <span>{metric.label}</span>
            </div>
            <p>{metric.value}</p>
          </article>
        ))
      }
    </div>
  </div>

  <div class='hero-panel' data-anim='hero-panel'>
    <CodeBlock lines={hero.commandPreview} />
  </div>
</section>

<style>
  .hero {
    width: min(1120px, 92vw);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 2rem;
    align-items: center;
    position: relative;
    min-width: 0;
  }

  .hero-copy {
    display: grid;
    gap: 0;
    justify-items: start;
    min-width: 0;
  }

  .hero-grid {
    position: absolute;
    inset: 0% 0 auto;
    height: 75%;
    background-image:
      linear-gradient(to right, var(--color-accent-grid-12) 1px, transparent 1px),
      linear-gradient(to bottom, var(--color-accent-grid-12) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: linear-gradient(
      to bottom,
      var(--color-overlay-dark-65),
      transparent 88%
    );
    z-index: -1;
    pointer-events: none;
  }

  .hero-copy h1 {
    margin: 1rem 0;
    line-height: 1.05;
    font-size: clamp(2rem, 3.5vw + 1rem, 4.5rem);
    letter-spacing: -0.03em;
    font-weight: 600;
    max-width: 16ch;
    background: linear-gradient(90deg, var(--color-text-primary), var(--color-text-muted));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .hero-copy p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.7;
    max-width: 58ch;
    font-size: clamp(1rem, 0.45vw + 0.75rem, 1rem);
    font-weight: 400;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .hero-actions {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    min-width: 0;
    max-width: 100%;
  }

  .hero-actions :global(.btn) {
    min-width: 0;
    max-width: 100%;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .hero-metrics {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
    max-width: 32rem;
    min-width: 0;
  }

  .hero-metrics article {
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 0.5rem 0.5rem;
    background: var(--color-surface-card-72);
    display: grid;
    gap: 0.25rem;
    transition: border-color 180ms ease, color 180ms ease;
    min-width: 0;
  }

  .hero-metrics article:hover {
    border-color: var(--color-accent-primary-62);
  }

  .metric-head {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-metric-muted);
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
    order: 2;
  }

  .metric-icon {
    color: currentColor;
  }

  .hero-metrics p {
    order: 1;
    margin: 0;
    color: var(--color-text-metric);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.15;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .hero-metrics span {
    order: 3;
    color: var(--color-text-metric-muted);
    font-size: 0.75rem;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .hero-metrics article:hover p,
  .hero-metrics article:hover span,
  .hero-metrics article:hover .metric-head {
    color: var(--color-text-metric-hover);
  }

  .hero-panel {
    position: relative;
    border-radius: 0.5rem;
    padding: 0;
    background: var(--color-surface-5);
    box-shadow: 0 20px 50px var(--color-shadow-deep);
    overflow: hidden;
    min-width: 0;
    max-width: 100%;
  }

  .hero-panel::before {
    content: "";
    position: absolute;
    inset: -20% 10% 60% -10%;
    background: radial-gradient(
      circle at center,
      var(--color-accent-violet-22),
      transparent 70%
    );
    filter: blur(24px);
    z-index: -1;
  }

  @media (max-width: 960px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-top: 1rem;
    }

    .hero-metrics {
      max-width: none;
    }
  }

  @media (max-width: 560px) {
    .hero-metrics {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 420px) {
    .hero {
      width: calc(100vw - 1rem);
      gap: 1rem;
    }

    .hero-copy h1 {
      max-width: 100%;
      font-size: clamp(1.25rem, 7vw, 1.75rem);
      margin: 0.75rem 0;
    }

    .hero-copy p {
      max-width: 100%;
      font-size: 0.75rem;
      line-height: 1.45;
    }

    .hero-metrics {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 220px) {
    .hero {
      width: calc(100vw - 0.5rem);
      gap: 0.5rem;
      padding-top: 0.5rem;
    }

    .hero-copy {
      gap: 0.25rem;
    }

    .hero-copy h1 {
      margin: 0.5rem 0;
      font-size: 1rem;
      line-height: 1.1;
      letter-spacing: -0.01em;
    }

    .hero-copy p {
      font-size: 0.75rem;
      line-height: 1.3;
    }

    .hero-grid {
      height: 60%;
      background-size: 18px 18px;
    }

    .hero-panel {
      border-radius: 0.25rem;
      box-shadow: none;
    }

    .hero-panel::before {
      display: none;
    }

    .hero-actions {
      margin-top: 1rem;
      gap: 0.5rem;
      flex-direction: column;
      align-items: stretch;
    }

    .hero-actions :global(.btn) {
      width: 100%;
      font-size: 0.75rem;
      line-height: 1.25;
      padding: 0.5rem;
      gap: 0.25rem;
    }

    .hero-metrics {
      margin-top: 1rem;
      gap: 0.25rem;
      grid-template-columns: 1fr;
    }

    .hero-metrics article {
      padding: 0.5rem;
      border-radius: 0.5rem;
      gap: 0.25rem;
    }

    .metric-head {
      gap: 0.25rem;
    }

    .hero-metrics p {
      font-size: 0.75rem;
      line-height: 1.25;
    }

    .hero-metrics span {
      font-size: 0.75rem;
      line-height: 1.25;
    }
  }

  @media (max-width: 120px) {
    .hero {
      width: calc(100vw - 0.25rem);
      gap: 0.25rem;
      padding-top: 0.25rem;
    }

    .hero-copy h1 {
      margin: 0.25rem 0;
      font-size: 0.75rem;
      line-height: 1.05;
      letter-spacing: 0;
    }

    .hero-copy p {
      font-size: 0.75rem;
      line-height: 1.15;
    }

    .hero-grid {
      height: 45%;
      background-size: 12px 12px;
    }

    .hero-actions {
      gap: 0.25rem;
    }

    .hero-actions :global(.btn) {
      font-size: 0.75rem;
      padding: 0.25rem;
      border-radius: 0.25rem;
    }

    .hero-metrics {
      gap: 0.25rem;
    }

    .hero-metrics article {
      padding: 0.25rem;
      border-radius: 0.25rem;
    }

    .metric-head,
    .hero-metrics p,
    .hero-metrics span {
      font-size: 0.75rem;
      line-height: 1.2;
    }
  }

  @media (max-width: 80px) {
    .hero {
      width: 100vw;
      gap: 0.25rem;
      padding-top: 0.25rem;
    }

    .hero-copy h1,
    .hero-copy p {
      max-width: 100%;
    }

    .hero-actions {
      margin-top: 0.5rem;
      gap: 0.25rem;
    }

    .hero-actions :global(.btn) {
      width: 100%;
      min-width: 0;
      padding: 0.25rem;
      font-size: 0.75rem;
      line-height: 1.1;
      gap: 0.25rem;
      border-radius: 0.25rem;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    .hero-actions :global(.btn .btn-icon) {
      min-width: 0.75rem;
      min-height: 0.75rem;
    }

    .hero-metrics {
      margin-top: 0.5rem;
      gap: 0.25rem;
      grid-template-columns: 1fr;
    }

    .hero-metrics article {
      padding: 0.25rem;
      border-radius: 0.25rem;
      gap: 0.25rem;
    }

    .metric-head {
      display: grid;
      grid-template-columns: 1fr;
      justify-items: start;
      gap: 0.25rem;
    }

    .metric-head,
    .hero-metrics p,
    .hero-metrics span {
      font-size: 0.75rem;
      line-height: 1.1;
      overflow-wrap: anywhere;
      word-break: break-word;
    }
  }

  @media (max-width: 60px) {
    .hero {
      gap: 0.25rem;
    }

    .hero-copy h1 {
      font-size: 0.75rem;
      line-height: 1;
      letter-spacing: 0;
    }

    .hero-copy p {
      font-size: 0.75rem;
      line-height: 1;
    }

    .hero-grid {
      display: none;
    }

    .hero-actions {
      gap: 0.25rem;
    }

    .hero-actions :global(.btn) {
      padding: 0.25rem;
      font-size: 0.75rem;
      line-height: 1;
      gap: 0.25rem;
    }

    .hero-metrics article {
      padding: 0.25rem;
      gap: 0.25rem;
    }

    .metric-head,
    .hero-metrics p,
    .hero-metrics span {
      font-size: 0.75rem;
      line-height: 1;
    }
  }
</style>
