---
import Section from "../ui/Section.astro";
import Button from "../ui/Button.astro";
import Icon from "../ui/Icon.astro";
import { docsTeaser } from "../../content/site/landing";
import { getIcon } from "../../lib/icons";
---

<Section title={docsTeaser.title} description={docsTeaser.description}>
  <div class="teaser" data-anim="docs-teaser">
    <div>
      <div class="teaser-kicker">
        <Icon icon={getIcon("book")} size="0.75rem" class="kicker-icon" />
        <span>Docs guide</span>
      </div>
      <p>
        Includes prerequisites, package commands per distro, required <code>sudo mvm host init</code>, and
        a verified quick start from kernel fetch to SSH.
      </p>
    </div>
    <div class="teaser-action">
      <Button href={docsTeaser.cta.href} label={docsTeaser.cta.label} iconLeft="book" iconRight={true} />
    </div>
  </div>
</Section>

<style>
  .teaser {
    border: 1px solid var(--border);
    border-radius: 1rem;
    padding: 1rem;
    background: linear-gradient(
      135deg,
      var(--color-surface-card-94-start),
      var(--color-surface-card-94-end)
    );
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    border-color: var(--color-border-soft);
    transition: border-color 180ms ease;
    min-width: 0;
    overflow: hidden;
  }

  .teaser > div {
    min-width: 0;
    max-width: 100%;
  }

  .teaser:hover {
    border-color: var(--color-accent-primary-62);
  }

  .teaser-action {
    flex: 0 0 auto;
    min-width: 0;
    max-width: 100%;
    width: fit-content;
  }

  .teaser-action :global(.btn) {
    width: auto;
    justify-content: center;
  }

  .teaser-action :global(.btn.primary) {
    background: var(--gradient-btn-primary);
  }

  .teaser-action :global(.btn.primary:hover),
  .teaser-action :global(.btn.primary:focus-visible) {
    background: var(--gradient-btn-primary-hover);
  }

  .teaser-action :global(.btn.primary:active) {
    background: var(--gradient-btn-primary-active);
  }

  .teaser p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.65;
    overflow-wrap: anywhere;
    word-break: break-word;
    hyphens: auto;
    transition: color 180ms ease;
  }

  .teaser-kicker {
    margin-bottom: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-list);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    transition: color 180ms ease;
  }

  .kicker-icon {
    color: var(--color-accent-primary);
    transition: color 180ms ease;
  }

  .teaser:hover p {
    color: var(--color-text-list);
  }

  .teaser:hover .teaser-kicker {
    color: var(--color-text-metric-hover);
  }

  .teaser:hover .kicker-icon {
    color: var(--color-accent-primary-88);
  }

  .teaser code {
    color: var(--color-accent-primary);
    font-family: "Geist Mono", "JetBrains Mono", "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 0.86em;
    overflow-wrap: anywhere;
    word-break: break-word;
    white-space: normal;
  }

  @media (max-width: 780px) {
    .teaser {
      flex-direction: column;
      align-items: stretch;
    }

    .teaser-action {
      align-self: flex-start;
      width: fit-content;
      max-width: 100%;
    }

    .teaser p {
      font-size: 1rem;
      line-height: 1.58;
    }

    .teaser-kicker {
      font-size: 0.75rem;
      gap: 0.5rem;
    }
  }

  @media (max-width: 420px) {
    .teaser {
      padding: 0.75rem;
      gap: 0.75rem;
    }

    .teaser p {
      font-size: 0.75rem;
      line-height: 1.42;
    }

    .teaser-kicker {
      font-size: 0.75rem;
      letter-spacing: 0.06em;
    }

    .teaser code {
      font-size: 0.72em;
    }
  }

  @media (max-width: 280px) {
    .teaser {
      padding: 0.5rem;
      gap: 0.5rem;
    }

    .teaser p {
      font-size: 0.75rem;
      line-height: 1.34;
    }

    .teaser-kicker {
      font-size: 0.5rem;
      gap: 0.25rem;
      letter-spacing: 0.05em;
    }

    .teaser code {
      font-size: 0.64em;
    }

    .teaser-action :global(.btn) {
      font-size: 0.75rem;
      padding: 0.25rem 0.5rem;
      line-height: 1.2;
    }
  }
</style>
