---
import { docsToc } from "../../content/site/docs";
---

<aside class="right-toc" data-anim="docs-right-toc">
  <p>On this page</p>
  <nav aria-label="On this page links">
    <ul>
      {
        docsToc.map((item) => (
          <li>
            <a href={`#${item.id}`} class={item.level === 3 ? "nested" : ""} data-docs-toc-link>
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</aside>

<style>
  .right-toc {
    position: sticky;
    top: calc(var(--header-height) + 3rem);
    align-self: start;
    border-left: 1px solid var(--border);
    padding-left: 1rem;

    /* Stay pinned to viewport even at the bottom of the page */
    max-height: calc(100vh - var(--header-height) - 5rem);
    overflow-y: auto;
  }

  .right-toc p {
    margin: 0 0 0.5rem;
    font-size: 0.75rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    font-weight: 600;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  a {
    display: inline-block;
    color: var(--text-soft);
    font-size: 0.75rem;
    line-height: 1.5;
    transition: color 180ms ease, text-decoration-color 180ms ease;
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 0.5rem;
  }

  a.nested {
    padding-left: 0.5rem;
    color: var(--color-text-subtle-2);
    font-size: 0.75rem;
  }

  a:hover,
  a.active {
    color: var(--text);
    text-decoration-color: var(--color-accent-primary-74);
  }

  @media (max-width: 1200px) {
    .right-toc {
      display: none;
    }
  }
</style>
