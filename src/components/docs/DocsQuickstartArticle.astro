---
import CodeBlock from "../ui/CodeBlock.astro";
import Callout from "../ui/Callout.astro";
import Note from "../ui/Note.astro";
import Icon from "../ui/Icon.astro";
import {
  distroPackages,
  docsMeta,
  installMethods,
  prerequisites,
  troubleshooting,
  hostInitSections,
  firstVmSections,
  vmCreateExplanation,
  vmCreateFlagLines,
  vmCreateExamples,
  sshExplanation,
  consoleExplanation,
  logsExplanation,
  snapshotExplanation,
  vmRmExplanation,
  vmInspectExplanation,
  imageSections,
  kernelSections,
  binarySections,
  keySections,
  networkSections,
  configSections,
  dependencySections,
  cloudInitSections,
  prerequisitesIntro,
  prerequisitesSubIntro,
  prerequisitesCallout,
  installIntro,
  installCallout,
  hostInitIntro,
  firstVmIntro,
  vmLifecycleIntro,
  resourceManagementIntro,
  networkIntro,
  dependenciesIntro,
  cloudInitIntro,
  troubleshootingIntro,
  debugMode,
  helpSection,
} from "../../content/site/docs";
import { getIcon } from "../../lib/icons";
---

<article class='article' data-anim='docs-main'>
  <!-- OVERVIEW -->
  <section id='overview' class='doc-section' data-anchor-title='Overview'>
    <p class='kicker'>mvmctl docs</p>
    <h1>{docsMeta.title}</h1>
    <p class='lead'>{docsMeta.intro}</p>
  </section>

  <!-- PREREQUISITES -->
  <section id='prerequisites' class='doc-section' data-anchor-title='Before you begin'>
    <h2>Before you begin</h2>
    <p set:html={prerequisitesIntro} />
    <ul>
      {prerequisites.map((item) => <li set:html={item} />)}
    </ul>

    <h3>System packages</h3>
    <p set:html={prerequisitesSubIntro} />

    <div class='terminal-shell' data-anim='docs-card-grid'>
      <div class='terminal-tabs' role='tablist' aria-label='Linux distro packages' data-anim='docs-package-tabs'>
        <button class='terminal-tab package-tab active' type='button' role='tab' aria-selected='true'
          id='pkg-tab-ubuntu' aria-controls='pkg-panel-ubuntu'
          data-package-tab data-package-target='ubuntu'>
          <Icon icon={getIcon("ubuntu")} size='0.75rem' class='terminal-tab-icon package-icon' />
          Ubuntu / Debian
        </button>
        <button class='terminal-tab package-tab' type='button' role='tab' aria-selected='false'
          id='pkg-tab-arch' aria-controls='pkg-panel-arch'
          data-package-tab data-package-target='arch'>
          <Icon icon={getIcon("arch")} size='0.75rem' class='terminal-tab-icon package-icon' />
          Arch
        </button>
      </div>
      <div class='terminal-frame package-panels'>
        <div class='package-panel active' data-package-panel data-package-id='ubuntu' role='tabpanel'
          id='pkg-panel-ubuntu' aria-labelledby='pkg-tab-ubuntu'>
          <CodeBlock lines={distroPackages.ubuntu.command} compact={true} />
        </div>
        <div class='package-panel' data-package-panel data-package-id='arch' role='tabpanel'
          id='pkg-panel-arch' aria-labelledby='pkg-tab-arch' hidden>
          <CodeBlock lines={distroPackages.arch.command} compact={true} />
        </div>
      </div>
    </div>

    <Callout text={prerequisitesCallout} />
  </section>

  <!-- INSTALL -->
  <section id='install' class='doc-section' data-anchor-title='Install mvm'>
    <h2>Install mvm</h2>
    <p set:html={installIntro} />

    <div class='terminal-shell' data-anim='docs-card-grid'>
      <div class='terminal-tabs' role='tablist' aria-label='Install options' data-anim='docs-install-tabs'>
        {installMethods.map((method, index) => (
          <button class={`terminal-tab install-tab ${index === 0 ? "active" : ""}`} type='button' role='tab'
            aria-selected={index === 0 ? "true" : "false"}
            id={`docs-install-tab-${method.id}`}
            aria-controls={`docs-install-panel-${method.id}`}
            data-doc-install-tab data-doc-install-target={method.id}>
            {method.icon ? <Icon icon={getIcon(method.icon)} size='0.75rem' class='terminal-tab-icon' /> : null}
            {method.title}
          </button>
        ))}
      </div>
      <div class='terminal-frame install-panels'>
        {installMethods.map((method, index) => (
          <div class={`install-panel ${index === 0 ? "active" : ""}`}
            data-doc-install-panel data-doc-install-id={method.id}
            role='tabpanel' id={`docs-install-panel-${method.id}`}
            aria-labelledby={`docs-install-tab-${method.id}`}
            hidden={index !== 0}>
            {method.description ? <p class='method-desc'>{method.description}</p> : null}
            <CodeBlock lines={method.code} compact={true} />
          </div>
        ))}
      </div>
    </div>

    <Callout text={installCallout} />
  </section>

  <!-- HOST INIT -->
  <section id='host-initialize' class='doc-section' data-anchor-title='Initialize host'>
    <h2>Initialize host</h2>
    <p set:html={hostInitIntro} />

    {hostInitSections.map((section) => (
      <div class="sub-section">
        <h3>{section.title}</h3>
        {section.description ? <p set:html={section.description} /> : null}
        {section.code ? (
          <div class='inline-block' data-anim='docs-card'>
            <CodeBlock lines={section.code} compact={true} />
          </div>
        ) : null}
        {section.items ? (
          <ul>{section.items.map((item) => <li set:html={item} />)}</ul>
        ) : null}
        {section.callout ? <Callout text={section.callout} /> : null}
      </div>
    ))}
  </section>

  <!-- FIRST VM -->
  <section id='first-vm' class='doc-section' data-anchor-title='Create your first VM'>
    <h2>Create your first VM</h2>
    <p set:html={firstVmIntro} />

    {firstVmSections.map((section) => (
      <div class="sub-section">
        <h3>{section.title}</h3>
        <p set:html={section.description} />
        <div class='inline-block' data-anim='docs-quick'>
          <CodeBlock lines={section.code} compact={true} />
        </div>
        {section.callouts ? section.callouts.map((g) => <Callout text={g} />) : null}
      </div>
    ))}
  </section>

  <!-- VM CREATE -->
  <section id='vm-create' class='doc-section' data-anchor-title='mvm vm create'>
    <h2>mvm vm create</h2>
    <p>{vmCreateExplanation.whatItDoes}</p>

    <h3 id='vm-create-flags'>All flags</h3>
    <div class='inline-block' data-anim='docs-card'>
      <CodeBlock lines={vmCreateFlagLines} compact={true} />
    </div>

    <h3>Examples</h3>
    {vmCreateExamples.map((ex) => (
      <div class="sub-section">
        <p><strong>{ex.title}</strong></p>
        <div class='inline-block' data-anim='docs-card'>
          <CodeBlock lines={ex.code} compact={true} />
        </div>
        <Note text={ex.note} />
      </div>
    ))}
    {vmCreateExplanation.callouts.map((g) => <Callout text={g} />)}
  </section>

  <!-- VM LIFECYCLE -->
  <section id='vm-lifecycle' class='doc-section' data-anchor-title='VM Lifecycle'>
    <h2>VM Lifecycle</h2>
    <p set:html={vmLifecycleIntro} />

    <!-- SSH -->
    <h3 id='vm-lifecycle-ssh'>mvm ssh</h3>
    <p>{sshExplanation.whatItDoes}</p>
    {sshExplanation.examples.map((ex) => (
      <div class='inline-block' data-anim='docs-card'><CodeBlock lines={[ex.code]} compact={true} /><Note text={ex.note} /></div>
    ))}
    {sshExplanation.callouts.map((g) => <Callout text={g} />)}

    <!-- Console -->
    <h3 id='vm-lifecycle-console'>mvm console</h3>
    <p>{consoleExplanation.whatItDoes}</p>
    {consoleExplanation.examples.map((ex) => (
      <div class='inline-block' data-anim='docs-card'><CodeBlock lines={[ex.code]} compact={true} /><Note text={ex.note} /></div>
    ))}
    {consoleExplanation.callouts.map((g) => <Callout text={g} />)}

    <!-- Logs -->
    <h3 id='vm-lifecycle-logs'>mvm logs</h3>
    <p>{logsExplanation.whatItDoes}</p>
    {logsExplanation.examples.map((ex) => (
      <div class='inline-block' data-anim='docs-card'><CodeBlock lines={[ex.code]} compact={true} /><Note text={ex.note} /></div>
    ))}
    {logsExplanation.callouts.map((g) => <Callout text={g} />)}

    <!-- Snapshots -->
    <h3 id='vm-lifecycle-snapshot'>mvm vm snapshot / load</h3>
    <p>{snapshotExplanation.whatItDoes}</p>
    {snapshotExplanation.examples.map((ex) => (
      <div class='inline-block' data-anim='docs-card'><CodeBlock lines={[ex.code]} compact={true} /><Note text={ex.note} /></div>
    ))}
    {snapshotExplanation.callouts.map((g) => <Callout text={g} />)}

    <!-- Inspect -->
    <h3>mvm vm ls / inspect</h3>
    <p>{vmInspectExplanation.whatItDoes}</p>
    {vmInspectExplanation.examples.map((ex) => (
      <div class='inline-block' data-anim='docs-card'><CodeBlock lines={[ex.code]} compact={true} /><Note text={ex.note} /></div>
    ))}

    <!-- Remove -->
    <h3 id='vm-lifecycle-rm'>mvm vm rm / prune</h3>
    <p>{vmRmExplanation.whatItDoes}</p>
    {vmRmExplanation.examples.map((ex) => (
      <div class='inline-block' data-anim='docs-card'><CodeBlock lines={[ex.code]} compact={true} /><Note text={ex.note} /></div>
    ))}
    {vmRmExplanation.callouts.map((g) => <Callout text={g} />)}
  </section>

  <!-- RESOURCE MANAGEMENT -->
  <section id='resource-management' class='doc-section' data-anchor-title='Resource Management'>
    <h2>Resource Management</h2>
    <p set:html={resourceManagementIntro} />

    <!-- Images -->
    <h3 id='resource-management-image'>mvm image</h3>
    {imageSections.map((s) => (
      <div class="sub-section">
        <p><strong>{s.title}</strong></p>
        {s.description ? <p set:html={s.description} /> : null}
        {s.items ? <ul>{s.items.map((item) => <li set:html={item} />)}</ul> : null}
        {s.code ? <div class='inline-block' data-anim='docs-card'><CodeBlock lines={s.code} compact={true} /></div> : null}
        {s.callout ? <Callout text={s.callout} /> : null}
      </div>
    ))}

    <!-- Kernels -->
    <h3 id='resource-management-kernel'>mvm kernel</h3>
    {kernelSections.map((s) => (
      <div class="sub-section">
        <p><strong>{s.title}</strong></p>
        {s.description ? <p set:html={s.description} /> : null}
        {s.code ? <div class='inline-block' data-anim='docs-card'><CodeBlock lines={s.code} compact={true} /></div> : null}
        {s.callout ? <Callout text={s.callout} /> : null}
      </div>
    ))}

    <!-- Binaries -->
    <h3 id='resource-management-bin'>mvm bin</h3>
    {binarySections.map((s) => (
      <div class="sub-section">
        <p><strong>{s.title}</strong></p>
        {s.description ? <p set:html={s.description} /> : null}
        {s.code ? <div class='inline-block' data-anim='docs-card'><CodeBlock lines={s.code} compact={true} /></div> : null}
        {s.callout ? <Callout text={s.callout} /> : null}
      </div>
    ))}

    <!-- Keys -->
    <h3 id='resource-management-key'>mvm key</h3>
    {keySections.map((s) => (
      <div class="sub-section">
        <p><strong>{s.title}</strong></p>
        {s.description ? <p set:html={s.description} /> : null}
        {s.code ? <div class='inline-block' data-anim='docs-card'><CodeBlock lines={s.code} compact={true} /></div> : null}
        {s.callout ? <Callout text={s.callout} /> : null}
      </div>
    ))}
  </section>

  <!-- NETWORK -->
  <section id='network-management' class='doc-section' data-anchor-title='Network Management'>
    <h2>Network Management</h2>
    <p set:html={networkIntro} />

    {networkSections.map((s) => (
      <div class="sub-section">
        <h3>{s.title}</h3>
        {s.description ? <p set:html={s.description} /> : null}
        {s.code ? <div class='inline-block' data-anim='docs-card'><CodeBlock lines={s.code} compact={true} /></div> : null}
        {s.callout ? <Callout text={s.callout} /> : null}
        {s.note ? <Note text={s.note} /> : null}
      </div>
    ))}
  </section>

  <!-- CONFIGURATION -->
  <section id='configuration' class='doc-section' data-anchor-title='Configuration'>
    <h2>Configuration</h2>

    {configSections.map((s) => (
      <div class="sub-section">
        <h3>{s.title}</h3>
        {s.description ? <p set:html={s.description} /> : null}
        {s.items ? <ol>{s.items.map((item) => <li set:html={item} />)}</ol> : null}
        {s.code ? <div class='inline-block' data-anim='docs-card'><CodeBlock lines={s.code} compact={true} /></div> : null}
        {s.callout ? <Callout text={s.callout} /> : null}
      </div>
    ))}
  </section>

  <!-- DEPENDENCIES -->
  <section id='dependencies' class='doc-section' data-anchor-title='Dependencies'>
    <h2>Dependencies</h2>
    <p set:html={dependenciesIntro} />

    {dependencySections.map((s) => (
      <div class="sub-section">
        <h3>{s.title}</h3>
        {s.description ? <p set:html={s.description} /> : null}
        {s.headers && s.rows ? (
          <div class="table-wrap">
            <table class="dep-table">
              <thead><tr>{s.headers.map((h) => <th>{h}</th>)}</tr></thead>
              <tbody>{s.rows.map((row) => <tr>{row.map((cell) => <td><code>{cell}</code></td>)}</tr>)}</tbody>
            </table>
          </div>
        ) : null}
        {s.code ? <div class='inline-block' data-anim='docs-card'><CodeBlock lines={s.code} compact={true} /></div> : null}
        {s.items ? <ul>{s.items.map((item) => <li set:html={item} />)}</ul> : null}
        {s.callout ? <Callout text={s.callout} /> : null}
      </div>
    ))}
  </section>

  <!-- CLOUD-INIT -->
  <section id='cloud-init' class='doc-section' data-anchor-title='Cloud-Init'>
    <h2>Cloud-Init</h2>
    <p set:html={cloudInitIntro} />

    {cloudInitSections.map((s) => (
      <div class="sub-section">
        <h3>{s.title}</h3>
        {s.description ? <p set:html={s.description} /> : null}
        {s.items ? <ul>{s.items.map((item) => <li set:html={item} />)}</ul> : null}
        {s.callout ? <Callout text={s.callout} /> : null}
      </div>
    ))}
  </section>

  <!-- TROUBLESHOOTING -->
  <section id='troubleshooting' class='doc-section' data-anchor-title='Troubleshooting'>
    <h2>Troubleshooting</h2>
    <p set:html={troubleshootingIntro} />

    {troubleshooting.map((issue) => (
      <div class='trouble-item' data-anim='docs-card'>
        <h3>{issue.problem}</h3>
        <div class='inline-block' data-anim='docs-card'>
          <CodeBlock lines={issue.fix} compact={true} />
        </div>
        {issue.note ? <Note text={issue.note} /> : null}
      </div>
    ))}

    <h3>{debugMode.title}</h3>
    <p set:html={debugMode.description} />
    <div class='inline-block' data-anim='docs-card'>
      <CodeBlock lines={debugMode.code} compact={true} />
    </div>
    <Callout text={debugMode.callout} />

    <h3>{helpSection.title}</h3>
    <p set:html={helpSection.description} />
    <ul>
      {helpSection.items.map((item) => <li set:html={item} />)}
    </ul>
  </section>
</article>

<script>
  import { icons } from "../../lib/icons";

  const initDocsTabs = () => {
    const packageTabs = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-package-tab]"));
    const packagePanels = Array.from(document.querySelectorAll<HTMLElement>("[data-package-panel]"));
    const activatePackage = (id: string) => {
      packageTabs.forEach((tab) => { const a = tab.dataset.packageTarget === id; tab.classList.toggle("active", a); tab.setAttribute("aria-selected", a ? "true" : "false"); });
      packagePanels.forEach((panel) => { const a = panel.dataset.packageId === id; panel.classList.toggle("active", a); panel.hidden = !a; });
    };
    packageTabs.forEach((tab) => { if (tab.dataset.tabsBound === "true") return; tab.dataset.tabsBound = "true"; tab.addEventListener("click", () => { if (tab.dataset.packageTarget) activatePackage(tab.dataset.packageTarget); }); });

    const installTabs = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-doc-install-tab]"));
    const installPanels = Array.from(document.querySelectorAll<HTMLElement>("[data-doc-install-panel]"));
    const activateInstall = (id: string) => {
      installTabs.forEach((tab) => { const a = tab.dataset.docInstallTarget === id; tab.classList.toggle("active", a); tab.setAttribute("aria-selected", a ? "true" : "false"); });
      installPanels.forEach((panel) => { const a = panel.dataset.docInstallId === id; panel.classList.toggle("active", a); panel.hidden = !a; });
    };
    installTabs.forEach((tab) => { if (tab.dataset.tabsBound === "true") return; tab.dataset.tabsBound = "true"; tab.addEventListener("click", () => { if (tab.dataset.docInstallTarget) activateInstall(tab.dataset.docInstallTarget); }); });
  };

  const initHeadingAnchors = () => {
    const setHeadingIcon = (slot: HTMLElement, iconName: "link" | "check" | "info") => {
      const [width, height, , , pathData] = icons[iconName].icon;
      const pathList = Array.isArray(pathData) ? pathData : [pathData];
      while (slot.firstChild) slot.removeChild(slot.firstChild);
      const svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
      svg.setAttribute("viewBox", `0 0 ${width} ${height}`); svg.setAttribute("width", "12"); svg.setAttribute("height", "12"); svg.setAttribute("fill", "currentColor"); svg.setAttribute("aria-hidden", "true");
      pathList.forEach((d) => { const p = document.createElementNS("http://www.w3.org/2000/svg", "path"); p.setAttribute("d", d); svg.appendChild(p); });
      slot.appendChild(svg);
    };
    let announcer = document.getElementById("heading-copy-status");
    if (!(announcer instanceof HTMLParagraphElement)) {
      announcer = document.createElement("p"); announcer.id = "heading-copy-status"; announcer.className = "sr-only";
      announcer.setAttribute("aria-live", "polite"); announcer.setAttribute("aria-atomic", "true"); document.body.appendChild(announcer);
    }
    const addCopyButton = (heading: HTMLElement, targetId: string, label: string) => {
      if (heading.dataset.headingCopyBound === "true") return;
      heading.dataset.headingCopyBound = "true";
      const wrap = document.createElement("span"); wrap.className = "heading-anchor-wrap";
      const btn = document.createElement("button"); btn.type = "button"; btn.className = "heading-anchor-btn";
      btn.setAttribute("aria-label", `Copy link to ${label}`);
      const icon = document.createElement("span"); icon.className = "heading-anchor-icon";
      setHeadingIcon(icon, "link"); btn.appendChild(icon);
      btn.addEventListener("click", async () => {
        const link = `${window.location.origin}${window.location.pathname.startsWith("/docs") ? window.location.pathname : "/docs/"}#${targetId}`;
        try {
          if (!window.isSecureContext) throw new Error("Clipboard requires secure context");
          if (!navigator.clipboard) throw new Error("Clipboard unavailable");
          await navigator.clipboard.writeText(link);
          setHeadingIcon(icon, "check"); btn.classList.add("copied"); announcer.textContent = `Copied link to ${label}.`;
        } catch { setHeadingIcon(icon, "info"); btn.classList.add("failed"); announcer.textContent = `Could not copy link to ${label}.`; }
        setTimeout(() => { setHeadingIcon(icon, "link"); btn.classList.remove("copied", "failed"); }, 1100);
      });
      wrap.appendChild(btn); heading.appendChild(wrap);
    };

    /* Add copy buttons to section-level headings (h1/h2 inside .doc-section) */
    Array.from(document.querySelectorAll<HTMLElement>(".doc-section[id]")).forEach((section) => {
      const heading = section.querySelector<HTMLElement>("h1, h2, h3");
      if (!heading) return;
      addCopyButton(heading, section.id, section.dataset.anchorTitle ?? section.id);
    });

    /* Add copy buttons to standalone h3[id] elements (sub-section anchors) */
    Array.from(document.querySelectorAll<HTMLElement>("h3[id]")).forEach((h3) => {
      addCopyButton(h3, h3.id, h3.textContent?.trim() ?? h3.id);
    });
  };

  const init = () => { initDocsTabs(); initHeadingAnchors(); };
  let frame = 0;
  const schedule = () => { if (frame) cancelAnimationFrame(frame); frame = requestAnimationFrame(() => { frame = 0; init(); }); };
  if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", schedule, { once: true }); else schedule();
  if (!document.documentElement.dataset.docsQuickstartBound) { document.documentElement.dataset.docsQuickstartBound = "true"; document.addEventListener("astro:page-load", schedule); }
</script>

<style>
  .doc-section {
    position: relative;
    border-bottom: none;
    scroll-margin-top: calc(var(--header-height) + 4rem);
    padding: 0.5rem 0;
  }

  /* h3 anchors (lifecycle sub-sections, resource types) need scroll room too */
  h3[id] {
    scroll-margin-top: calc(var(--header-height) + 4rem);
  }
  .doc-section::after {
    content: "";
    display: block;
    width: 100%;
    height: 1px;
    margin: 2.5rem 0 1rem;
    background: linear-gradient(
      90deg,
      var(--border) 0%,
      var(--border) 40%,
      transparent 100%
    );
  }
  .doc-section:last-child { padding-bottom: 0; }
  .doc-section:last-child::after { display: none; }

  .sub-section {
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
    padding: 1rem 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: var(--color-surface-3);
    transition: border-color 180ms ease;
  }
  .sub-section:hover {
    border-color: var(--color-accent-primary-45);
  }
  .sub-section:first-of-type {
    margin-top: 1rem;
  }
  .sub-section:last-of-type {
    margin-bottom: 0.5rem;
  }

  .kicker {
    margin: 0;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    color: var(--text-soft);
  }

  h1 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0.75rem 0;
    font-size: clamp(2rem, 1.25vw + 1.25rem, 2.5rem);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: -0.03em;
  }
  @media (max-width: 680px) { h1 { font-size: clamp(1.5rem, 6.2vw, 2rem); line-height: 1.12; gap: 0.5rem; } }
  @media (max-width: 420px) { h1 { font-size: clamp(1.25rem, 7.4vw, 1.5rem); line-height: 1.16; gap: 0.25rem; } }

  .lead {
    margin: 0 0 1.25rem;
    font-size: 1rem;
    color: var(--text-soft);
    line-height: 1.75;
    max-width: 65ch;
  }

  h2 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.75rem;
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  h3 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 1.75rem 0 0.5rem;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-text-muted);
