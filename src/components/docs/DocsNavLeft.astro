---
import Icon from "../ui/Icon.astro";
import { docsNav } from "../../content/site/docs";
import { getIcon } from "../../lib/icons";
---


<aside class="left-nav" data-anim="docs-sidebar">
  <p class="title">Getting started</p>
  <nav aria-label="Documentation sections">
    <ul>
      {docsNav.map((item) => (
        <li class={item.children ? "has-children" : ""}>
          <a href={`#${item.id}`} data-docs-left-link>
            <Icon icon={getIcon(item.icon)} size="0.75rem" class="icon" />
            <span>{item.label}</span>
          </a>
          {item.children ? (
            <ul class="nav-sublist">
              {item.children.map((child) => (
                <li>
                  <a href={`#${child.id}`} data-docs-left-link class="sub-link">
                    <span>{child.label}</span>
                  </a>
                </li>
              ))}
            </ul>
          ) : null}
        </li>
      ))}
    </ul>
  </nav>
</aside>

<style>
  .left-nav {
    position: sticky;
    top: calc(var(--header-height) + 3rem);
    align-self: start;
    padding: 0;
  }

  .title {
    margin: 0 0 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.35rem;
  }

  .nav-sublist {
    padding-left: 1.25rem !important;
    margin-top: 0.2rem !important;
    gap: 0.15rem !important;
    border-left: 1px solid var(--border);
  }

  a {
    text-decoration: none;
    color: var(--text-soft);
    border-left: 2px solid transparent;
    border-radius: 0.5rem;
    padding: 0.4rem 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    transition: background-color 160ms ease, border-color 160ms ease, color 160ms ease;
    text-underline-offset: 0.5rem;
    width: 100%;
  }

  a:hover,
  a.active {
    color: var(--text);
    background: transparent;
    border-left-color: var(--color-accent-primary-62);
  }

  .sub-link {
    font-size: 0.7rem;
    padding: 0.25rem 0.5rem;
    color: var(--color-text-subtle-2);
    border-left: none;
  }

  .sub-link:hover {
    color: var(--text);
    border-left: none;
    background: transparent;
  }

  .icon {
    color: var(--color-text-subtle);
    flex-shrink: 0;
  }

  @media (max-width: 980px) {
    .left-nav {
      position: fixed;
      top: calc(var(--header-height) + 1.5rem);
      left: 0.75rem;
      right: 0.75rem;
      z-index: 2200;
      width: auto;
      max-width: min(26rem, calc(100vw - 1.5rem));
      min-width: 0;
      margin-inline: auto;
      padding: 0.75rem;
      border: 1px solid var(--color-border-light);
      border-radius: 0.75rem;
      background: var(--color-overlay-dark-94);
      backdrop-filter: blur(10px);
      box-shadow: 0 10px 26px var(--color-overlay-black-32);
      opacity: 0 !important;
      transform: translateY(-0.25rem) scale(0.98) !important;
      pointer-events: none;
      visibility: hidden;
      transition: opacity 180ms ease, transform 180ms ease, visibility 0s linear 180ms;
    }

    .left-nav.mobile-open {
      opacity: 1 !important;
      transform: translateY(0) scale(1) !important;
      pointer-events: auto;
      visibility: visible;
      transition: opacity 180ms ease, transform 180ms ease, visibility 0s linear 0s;
    }

    .left-nav .title {
      margin-bottom: 0.75rem;
    }

    .left-nav ul {
      gap: 0.5rem;
      min-width: 0;
    }

    .nav-sublist {
      gap: 0.25rem !important;
    }

    .left-nav a {
      width: 100%;
      padding: 0.5rem;
      border-radius: 0.5rem;
      min-width: 0;
      white-space: normal;
      overflow-wrap: anywhere;
      word-break: break-word;
      align-items: flex-start;
      line-height: 1.3;
    }

    .left-nav a span {
      display: inline-block;
      min-width: 0;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    .left-nav li {
      min-width: 0;
    }

    @media (max-width: 280px) {
      .left-nav {
        left: 0.5rem;
        right: 0.5rem;
        max-width: calc(100vw - 1rem);
        padding: 0.5rem;
        box-sizing: border-box;
      }
      .left-nav ul { gap: 0.5rem; }
      .left-nav a { font-size: 0.75rem; padding: 0.25rem; gap: 0.25rem; max-width: 100%; }
    }
  }
</style>
